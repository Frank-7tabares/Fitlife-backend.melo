DB_HOST=tu-servicio.a.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=tu-password-aiven
DB_NAME=defaultdb
DB_USE_SSL=true
DB_SSL_CA=ca.pem

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

FRONTEND_URL=http://localhost:5173

EMAIL_FROM=tu-correo@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASSWORD="app-password-de-16-caracteres-con-espacios"

# Render bloquea conexiones SMTP salientes (587/465). En producción ahí usa Resend por HTTPS:
# https://resend.com — API Keys → copia la key; Domains o prueba con onboarding@resend.dev
# Si RESEND_API_KEY está definida, el backend ignora SMTP para el reset de contraseña.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=FitLife <onboarding@resend.dev>

# false = correo SMTP en un hilo después de guardar el token (recomendado en Render; evita timeout HTTP).
# true = envía en la misma petición (local / depuración).
PASSWORD_RESET_EMAIL_SYNC=false

DEBUG=false
API_VERSION=v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LOG_LEVEL=INFO
